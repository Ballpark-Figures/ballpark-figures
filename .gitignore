# Per-video sub-repos (each is its own git repo)
hangman/
battleship/
yahtzee/
mastermind/
ballpark-figures/

# Per-scene git worktrees (<video>-sceneNN) — created by /scene for concurrent
# sessions; they're checkouts of a sub-repo, never tracked by the umbrella.
*-scene[0-9]*/

# Python
*.egg-info/
__pycache__/
*.py[cod]
.venv/
venv/

# Manim / generated media (never commit renders)
media/
*.mp4
*.mov
*.wav
*.mp3

# Private Claude tooling — real files live in the separate private `dotclaude`
# repo and are symlinked into .claude/ per machine (see dotclaude/README.md).
# Keep these OUT of this public repo.
.claude/commands
.claude/settings.local.json
bpkfigures/CLAUDE.private.md

# OS / editor junk
.DS_Store
